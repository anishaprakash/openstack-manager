# ─── API Security ─────────────────────────────────────────────────────────────
# Change this to a strong random secret in production.
API_KEY=changeme

# ─── OpenStack Credentials ────────────────────────────────────────────────────
# Example for OVH Public Cloud (update with your own values)
OS_AUTH_URL=https://auth.cloud.ovh.net/v3
OS_IDENTITY_API_VERSION=3
OS_USERNAME=user-xxxxxxxxxxxxxxxx
OS_PASSWORD=your-openstack-password
OS_TENANT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OS_TENANT_NAME=your-project-id
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=CA-EAST-TOR

# Or for local DevStack:
# OS_AUTH_URL=http://localhost:5000/v3
# OS_USERNAME=admin
# OS_PASSWORD=secret
# OS_PROJECT_NAME=admin
# OS_REGION_NAME=RegionOne

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_TITLE=OpenStack VM Manager
APP_VERSION=0.1.0
DEBUG=false
